# PostgreSQL (docker-compose)
DATABASE_URL=postgresql://mindora:mindora@localhost:5432/mindora

# MongoDB (community-service, Sprint 1)
MONGODB_URI=mongodb://localhost:27017/mindora

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://mindora:mindora@localhost:5672

# Auth / Kong JWT (use same secret in Kong and auth-service)
# Must match infrastructure/kong/kong.yml jwt_secrets.secret for local dev
JWT_SECRET=mindora-dev-jwt-secret-change-in-production

# Auth service
APP_BASE_URL=http://localhost:3001

# Google OAuth (optional — required for OAuth flow testing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/oauth/google/callback
